# ==============================================================================
# CONFIGURACIÓN GENERAL Y VARIABLES DE ENTORNO — FINLOGIC
# ==============================================================================

# --- Base de Datos (MySQL) ---
# Host de conexión: usar 'db' dentro de la red Docker, 'localhost' desde tu máquina local
DB_HOST=db
DB_PORT=3306
# Puerto que se expondrá en tu máquina local para conectar un cliente MySQL externo (como DBeaver)
DB_PORT_EXTERNAL=3307
DB_USER=user
DB_PASSWORD=TU_PASSWORD_DB
DB_NAME=finlogic
DB_ROOT_PASSWORD=TU_PASSWORD_ROOT

# --- API Backend (Node.js + Express) ---
PORT=3000
# Clave secreta para la firma de tokens JWT de sesión
JWT_SECRET=TU_SECRET_JWT

# --- App Frontend (Vite + Vue.js) ---
# Puerto expuesto para el servidor local de desarrollo del Frontend
VITE_PORT=8080
# URL del endpoint del backend al que llamará el cliente (navegador)
VITE_API_URL=http://localhost:3000/api
